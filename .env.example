# Server
PORT=8010
NODE_ENV=development

# SQLite database location
DATABASE_PATH=./data/caint.db

# Session signing secret — generate with: openssl rand -base64 32
SESSION_SECRET=replace-me-with-a-long-random-string

# Initial user — seeded on first boot only
INITIAL_USERNAME=admin
INITIAL_PASSWORD=changeme

# Vue dev server (used by client during npm run dev)
VITE_API_BASE=http://localhost:8010
